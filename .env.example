# Catalyst IQ - example environment configuration.
#
# Copy to `.env` and fill in real values locally (and in your host's
# environment settings for deploys). NEVER commit a real .env or real
# secrets - `.env` is gitignored. Placeholders only below.

# --- Core app ------------------------------------------------------------
# API key protecting the action/ingest endpoints.
ACTION_API_KEY=

# Storage. Defaults to a local SQLite file; point at Postgres in production.
DATABASE_URL=sqlite:///./catalystiq.db

# Comma-separated browser origins allowed to call the API directly (Vite dev).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Market data source priority (§16) -----------------------------------
# Yahoo is the initial primary historical source; Twelve Data is the
# optional secondary/validation source.
MARKET_DATA_PRIMARY_PROVIDER=yahoo
MARKET_DATA_SECONDARY_PROVIDER=twelve_data

# --- Per-source enable flags ---------------------------------------------
# Yahoo and the NYSE calendar have no flag - they're keyless and always
# available. Secure-by-default: sources needing a key or required config
# default off; flip one to true only after setting its config below (an
# enabled source with missing config fails startup). Keyless FINRA/Nasdaq
# Trader default on.
ENABLE_TWELVE_DATA=false
ENABLE_SEC_EDGAR=false
ENABLE_FRED=false
ENABLE_BLS=false
ENABLE_BEA=false
ENABLE_FINRA=true
ENABLE_NASDAQ_TRADER=true
ENABLE_WEBULL=false

# --- Provider API keys / credentials -------------------------------------
# Only required when the owning source is enabled AND its adapter is wired.
# Leave blank for sources you aren't using.
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
TWELVE_DATA_API_KEY=

# Optional local cap so a free Twelve Data plan isn't drained in one run
# (0 = no cap).
TWELVE_DATA_DAILY_REQUEST_BUDGET=0

# Cross-provider price comparison tolerance (percent). A larger relative
# difference between the primary and secondary provider raises a data-quality
# warning; values are never averaged.
PROVIDER_COMPARISON_TOLERANCE_PCT=0.5

# Yahoo-outage fallback to the secondary provider - only used when explicitly
# enabled. The primary is never silently replaced.
MARKET_DATA_FALLBACK_ENABLED=false

# --- Order submission (disabled by default) ------------------------------
# Order submission is OFF unless you explicitly enable it, and every order
# then requires a single-use confirmation token bound to the exact order
# details you reviewed. Paper and live are separate; live stays unavailable
# until separately approved (it is refused even if its flag is set).
TRADING_MODE=paper
ENABLE_PAPER_ORDER_SUBMISSION=false
ENABLE_LIVE_ORDER_SUBMISSION=false
ORDER_CONFIRMATION_SECRET=
ORDER_CONFIRMATION_TTL_SECONDS=300

# Separate live-trading credentials (unused until live is approved).
WEBULL_LIVE_APP_KEY=
WEBULL_LIVE_APP_SECRET=
WEBULL_LIVE_ACCOUNT_ID=

# SEC EDGAR requires a descriptive User-Agent with contact info per its
# fair-access policy (not a secret, but required when SEC is enabled).
SEC_USER_AGENT="Catalyst IQ contact-email@example.com"

# Webull OpenAPI credentials (brokerage / order verification only; read-only
# in this build - order submission stays disabled).
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_ACCOUNT_ID=
WEBULL_REGION_ID=us
WEBULL_API_ENDPOINT=
WEBULL_TOKEN_DIR=
