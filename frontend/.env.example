# Copy to .env for local development.
#
# DEV-ONLY: VITE_ACTION_API_KEY gets baked into the browser bundle by Vite.
# That's fine for pointing your local frontend at your local backend, but
# it must never be set to a real/shared key in anything that gets deployed -
# see the warning in src/lib/api.ts.

VITE_API_BASE_URL=http://localhost:8000
VITE_ACTION_API_KEY=dev-local-key
